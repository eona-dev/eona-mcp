#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [[ -f "${ROOT_DIR}/eona-mcp.env" ]]; then
  # shellcheck source=/dev/null
  source "${ROOT_DIR}/eona-mcp.env"
fi
export EONA_RELEASE_ROOT="${EONA_RELEASE_ROOT:-${ROOT_DIR}}"
export EONA_FAMILY_ROOT="${EONA_FAMILY_ROOT:-${HOME}/.eona}"
export EONA_MCP_INSTALL_ROOT="${EONA_MCP_INSTALL_ROOT:-${ROOT_DIR}}"
export EONA_MCP_WORKSPACE="${EONA_MCP_WORKSPACE:-${EONA_FAMILY_ROOT}/workspace}"
export EONA_CLI="${EONA_CLI:-${EONA_FAMILY_ROOT}/eona-cli/bin/eona}"
export PYTHONPATH="${ROOT_DIR}/src${PYTHONPATH:+:${PYTHONPATH}}"
exec python3 -m eona_mcp.http_server "$@"
