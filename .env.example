# Docker image references.
EONA_MCP_IMAGE=ghcr.io/isemptyc/eona-mcp:latest
EONA_CADIS_DATASETS_IMAGE=ghcr.io/isemptyc/eona-cadis-datasets:latest
EONA_MCP_HTTP_PREPARE_LOCATION=1

# Project A is enabled by default.
EONA_PROJECT_A_ID=project-a
EONA_PROJECT_A_DESCRIPTION=Photos from one mounted library.
EONA_PROJECT_A_PHOTOS=/path/to/photos
EONA_PROJECT_A_PORT=8711
EONA_PROJECT_A_MCP_PATH=/mcp
EONA_PROJECT_A_ASSET_BASE_URL=http://localhost:8711/assets
EONA_PROJECT_A_BEARER_TOKEN=change-me-project-a
EONA_PROJECT_A_ALLOWED_ORIGINS=

# Project B is optional. Start it with:
# docker compose --profile project-b up
EONA_PROJECT_B_ID=project-b
EONA_PROJECT_B_DESCRIPTION=Photos from another mounted library.
EONA_PROJECT_B_PHOTOS=/path/to/other/photos
EONA_PROJECT_B_PORT=8712
EONA_PROJECT_B_MCP_PATH=/mcp
EONA_PROJECT_B_ASSET_BASE_URL=http://localhost:8712/assets
EONA_PROJECT_B_BEARER_TOKEN=change-me-project-b
EONA_PROJECT_B_ALLOWED_ORIGINS=
